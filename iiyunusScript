-- --- LOGIQUE ANTI-RING ---
RS.Heartbeat:Connect(function()
    if not arConfig.enabled then return end
    pcall(function() sethiddenproperty(player, "SimulationRadius", math.huge) end)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local found = false
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v.Anchored and not v:IsDescendantOf(char) then
            if not v.Parent:FindFirstChild("Humanoid") then
                local dist = (v.Position - root.Position).Magnitude
                if dist <= arConfig.distance then
                    found = true
                    local dir = (v.Position - root.Position).Unit
                    v.Velocity = (dir + Vector3.new(0, 0.1, 0)) * arConfig.currentForce
                    v.RotVelocity = Vector3.new(15, 15, 15)
                end
            end
        end
    end
    if found then
        if arConfig.currentForce < arConfig.maxForce then arConfig.currentForce = arConfig.currentForce + 25 end
    else
        arConfig.currentForce = arConfig.baseForce
    end
end)

