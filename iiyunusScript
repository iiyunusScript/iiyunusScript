local function cleanBotESP(model)
    if espBots[model] then
        if espBots[model].highlight then espBots[model].highlight:Destroy() end
        if espBots[model].bgui then espBots[model].bgui:Destroy() end
        if espBots[model].conn then espBots[model].conn:Disconnect() end
        espBots[model] = nil
    end
end

local function applyBotESP(model)
    if not config.ESP_BOTS_ENABLED then return end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local hrp = getAttachmentPart(model)
    if not hrp then return end
    
    cleanBotESP(model)
    
    local color = Color3.new(1, 0.8, 0)
    local highlight = Instance.new("Highlight", model); highlight.FillTransparency = 0.6; highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    local bgui = Instance.new("BillboardGui", hrp); bgui.Size = UDim2.new(0, 150, 0, 50); bgui.StudsOffset = Vector3.new(0, 3.5, 0); bgui.AlwaysOnTop = true
    local nameLabel = Instance.new("TextLabel", bgui); nameLabel.Size = UDim2.new(1, 0, 0.5, 0); nameLabel.BackgroundTransparency = 1; nameLabel.TextColor3 = color; nameLabel.Font = Enum.Font.GothamBold; nameLabel.TextSize = 14; nameLabel.Text = model.Name
    local infoLabel = Instance.new("TextLabel", bgui); infoLabel.Size = UDim2.new(1, 0, 0.4, 0); infoLabel.Position = UDim2.new(0, 0, 0.45, 0); infoLabel.BackgroundTransparency = 1; infoLabel.TextColor3 = Color3.new(0, 0, 0); infoLabel.Font = Enum.Font.GothamSemibold; infoLabel.TextSize = 12
    
    local conn = RS.RenderStepped:Connect(function()
        -- MODIFIÉ : Ne se supprime plus si Health <= 0
        if not config.ESP_BOTS_ENABLED or not model.Parent or not hrp.Parent then 
            cleanBotESP(model) 
            return 
        end
        local myAttach = getAttachmentPart(player.Character)
        if myAttach then
            local dist = math.floor((myAttach.Position - hrp.Position).Magnitude)
            infoLabel.Text = math.floor(hum.Health) .. " HP | " .. dist .. "m"
        end
    end)
    espBots[model] = {highlight = highlight, bgui = bgui, conn = conn}
end

