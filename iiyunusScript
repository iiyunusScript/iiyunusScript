    txt.BackgroundTransparency = 1; txt.Font = Enum.Font.Gotham; txt.TextSize = 12; txt.TextColor3 = Color3.new(1, 1, 1); txt.TextWrapped = true; txt.RichText = true
    
    if translated and translated:lower() ~= original:lower() then
        txt.Text = "<b>" .. sender .. "</b>: " .. translated .. " <font color='#888888' size='10'>[" .. original .. "]</font>"
