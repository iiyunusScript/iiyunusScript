    txt.TextSize = 12
    txt.TextColor3 = Color3.new(1, 1, 1)
    txt.TextWrapped = true
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.RichText = true
    
    if translated and translated:lower() ~= original:lower() then
        txt.Text = "<b>" .. sender .. "</b>: " .. translated .. " <font color='#888888' size='10'>[" .. original .. "]</font>"
    else
        txt.Text = "<b>" .. sender .. "</b>: " .. original
    end

    task.wait(0.05)
    chatFrame.CanvasPosition = Vector2.new(0, chatFrame.AbsoluteContentSize.Y)
end

