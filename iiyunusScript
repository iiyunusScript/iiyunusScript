local function getESPColor(targetPlr)
    if targetPlr.Team ~= nil and player.Team ~= nil then
        return (targetPlr.Team == player.Team) and Color3.new(0, 0, 1) or Color3.new(1, 0, 0)
    end
    return Color3.new(1, 1, 1)
end

local function applyPlayerESP(targetPlr)
    if targetPlr == player then return end
    local function setup(char)
        local hum = char:WaitForChild("Humanoid")
        local hrp = char:WaitForChild("HumanoidRootPart")
        local highlight = Instance.new("Highlight", char)
        highlight.FillTransparency = 0.5
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        local bgui = Instance.new("BillboardGui", char)
        bgui.Size = UDim2.new(0, 150, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 3.5, 0)
        bgui.AlwaysOnTop = true
        
        local nameLabel = Instance.new("TextLabel", bgui)
        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextColor3 = Color3.new(1, 1, 1)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 14

        local infoLabel = Instance.new("TextLabel", bgui)
        infoLabel.Size = UDim2.new(1, 0, 0.4, 0)
        infoLabel.Position = UDim2.new(0, 0, 0.45, 0)
        infoLabel.BackgroundTransparency = 1
        infoLabel.TextColor3 = Color3.new(1, 1, 1)
        infoLabel.Font = Enum.Font.GothamSemibold
        infoLabel.TextSize = 12

        RS.RenderStepped:Connect(function()
            if _G.ESP_ALL_ENABLED and char.Parent and hrp.Parent then
                local color = getESPColor(targetPlr)
                highlight.Enabled, highlight.OutlineColor, highlight.FillColor = true, color, color
                nameLabel.Text = targetPlr.Name
                nameLabel.TextColor3 = color
                local dist = math.floor((player.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
                infoLabel.Text = math.floor(hum.Health) .. " HP | " .. dist .. "m"
                bgui.Enabled = true
            else
                highlight.Enabled, bgui.Enabled = false, false
            end
        end)
    end
    targetPlr.CharacterAdded:Connect(setup)
    if targetPlr.Character then setup(targetPlr.Character) end
end

local function applyBotESP(model)
    local hum = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
    if not hum or not hrp then return end
    local name = model.Name:lower()
    local ignoreNames = {"merchant", "shop", "magasin", "quest", "vendeur", "dealer", "job", "dummy"}
    for _, word in pairs(ignoreNames) do if name:find(word) then return end end
    if hrp.Anchored and hum.MaxHealth > 100000 then return end
    local color = Color3.new(1, 0.8, 0)
    local highlight = Instance.new("Highlight", model)
    highlight.FillTransparency = 0.6
    highlight.OutlineColor = color
    highlight.FillColor = color
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    local bgui = Instance.new("BillboardGui", hrp)
    bgui.Size = UDim2.new(0, 150, 0, 50)
    bgui.StudsOffset = Vector3.new(0, 3.5, 0)
    bgui.AlwaysOnTop = true
    local nameLabel = Instance.new("TextLabel", bgui)
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = color
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.Text = model.Name
    local infoLabel = Instance.new("TextLabel", bgui)
    infoLabel.Size = UDim2.new(1, 0, 0.4, 0)
    infoLabel.Position = UDim2.new(0, 0, 0.45, 0)
    infoLabel.BackgroundTransparency = 1
    infoLabel.TextColor3 = color
    infoLabel.Font = Enum.Font.GothamSemibold
    infoLabel.TextSize = 12
    local conn
    conn = RS.RenderStepped:Connect(function()
        if not model.Parent or not hrp.Parent or hum.Health <= 0 then
            highlight:Destroy(); bgui:Destroy(); conn:Disconnect(); return
        end
        if _G.ESP_BOTS_ENABLED and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            highlight.Enabled, bgui.Enabled = true, true
            local dist = math.floor((player.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
            infoLabel.Text = math.floor(hum.Health) .. " HP | " .. dist .. "m"
        else
            highlight.Enabled, bgui.Enabled = false, false
        end
    end)
end

local function scanForBots()
    workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("Humanoid") then
            task.wait(0.5)
            if not game.Players:GetPlayerFromCharacter(obj.Parent) then applyBotESP(obj.Parent) end
        end
    end)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Humanoid") and not game.Players:GetPlayerFromCharacter(v.Parent) then applyBotESP(v.Parent) end
    end
end

