local function addToggle(parent, text, configKey, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -5, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    btn.Text = "  " .. text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    local statusBox = Instance.new("Frame", btn)
    statusBox.Size = UDim2.new(0, 16, 0, 16)
    statusBox.Position = UDim2.new(1, -26, 0.5, -8)
    
    local isEnabled = false
    if configKey == "AntiRingEnabled" then isEnabled = arConfig.enabled else isEnabled = config[configKey] end
    
    statusBox.BackgroundColor3 = isEnabled and Color3.new(1, 1, 1) or Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", statusBox).CornerRadius = UDim.new(0, 4)
    local stroke = Instance.new("UIStroke", statusBox)
    stroke.Color = isEnabled and Color3.new(1, 1, 1) or Color3.fromRGB(70, 70, 70)
    
    local function updateVisual(state)
        statusBox.BackgroundColor3 = state and Color3.new(1, 1, 1) or Color3.fromRGB(15, 15, 15)
        stroke.Color = state and Color3.new(1, 1, 1) or Color3.fromRGB(70, 70, 70)
    end

    btn.MouseButton1Click:Connect(function()
        local newState
        if configKey == "AntiRingEnabled" then
            arConfig.enabled = not arConfig.enabled
            newState = arConfig.enabled
        else
            config[configKey] = not config[configKey]
            newState = config[configKey]
        end
        if callback then callback(newState) end
        updateVisual(newState)
        saveSettings()
    end)
    
    if text == "Noclip" then updateNoclipUI = updateVisual end
end

