local function getTargetPlayer()
    local text = searchInput.Text:lower()
    for _, p in pairs(game.Players:GetPlayers()) do
        if string.find(p.Name:lower(), text) or string.find(p.DisplayName:lower(), text) then return p end
    end
    return nil
end

