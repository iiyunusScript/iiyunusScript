local function loadSettings()
    if isfile and isfile(SETTINGS_FILE) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(SETTINGS_FILE))
            if decoded.main then
                for k, v in pairs(decoded.main) do config[k] = v end
            end
            if decoded.ring ~= nil then arConfig.enabled = decoded.ring end
        end)
    end
end

